{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'mergeConfidence:all-badges',
    'config:best-practices',
  ],
  nix: {
    enabled: true,
  },
  packageRules: [
    {
      matchManagers: [
        'nix',
      ],
      matchDepNames: [
        'nixpkgs_stable',
      ],
      enabled: false,
    },
  ],
  customManagers: [
    {
      customType: 'regex',
      managerFilePatterns: [
        '/^flake\\.nix$/',
      ],
      matchStrings: [
        'nixpkgs_stable\\.url\\s*=\\s*"github:nixos/nixpkgs/(?<currentValue>release-\\d\\d\\.\\d\\d)";',
      ],
      depNameTemplate: 'nixpkgs_stable',
      packageNameTemplate: 'https://github.com/NixOS/nixpkgs',
      datasourceTemplate: 'git-refs',
      versioningTemplate: 'nixpkgs',
      autoReplaceStringTemplate: 'nixpkgs_stable.url = "github:nixos/nixpkgs/{{{newValue}}}";'
    },
  ],
}
