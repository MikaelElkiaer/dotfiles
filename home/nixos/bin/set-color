#!/usr/bin/env bash

set -Eeuo pipefail

function set-color() {
  local color="$1"
  local COLORMODE="${COLORMODE:-ansi}"
  local COLORPOS="${COLORPOS:-fg}"
  if [ "${COLORMODE:-}" = "tmux" ]; then
    if [ "$color" = "reset" ]; then
      echo -n "#[default]"
    else
      echo -n "#[${COLORPOS}=colour${color}]"
    fi
  else
    if [ "$color" = "reset" ]; then
      printf "\033[0m"
    elif [ "${COLORPOS:-}" = "fg" ]; then
      printf "\033[38;5;%sm" "$color"
    else
      printf "\033[48;5;%sm" "$color"
    fi
  fi
}

# If run directly as a script
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  if [ "$#" -ne 1 ]; then
    echo "Usage: $0 <color-name>" >&2
    exit 1
  fi
  set-color "$1"
fi
