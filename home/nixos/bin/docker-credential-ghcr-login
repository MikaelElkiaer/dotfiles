#!/usr/bin/env bash

set -Eeuo pipefail

# Check for required CLI dependencies
if ! command -v gh >/dev/null 2>&1; then
  echo "Error: github-cli (gh) is required but not installed." >&2
  exit 1
fi

if ! command -v jq >/dev/null 2>&1; then
  echo "Error: jq is required but not installed." >&2
  exit 1
fi

VERSION="0.1.0"

case "${1:-}" in
version)
  echo "$VERSION"
  ;;
erase | store)
  echo "not implemented" >&2
  exit 1
  ;;
list)
  # Parse local gh auth status to output a JSON map of hostnames -> active/first usernames
  gh auth status --json hosts --jq '.hosts | to_entries | map({key: .key, value: (.value[] | select(.active == true).login // .value[0].login)}) | from_entries' 2>/dev/null || echo '{}'
  ;;
get)
  # Read the raw ServerURL from stdin safely (even if no trailing newline)
  read -r SERVER_URL || [[ -n "$SERVER_URL" ]]

  # Clean the input to get just the hostname (e.g., https://ghcr.io/v2/ -> ghcr.io)
  HOST="${SERVER_URL#*://}"
  HOST="${HOST%%/*}"
  HOST="${HOST%%:*}"

  # If the request is for ghcr.io or typo gchr.io, map it to github.com
  if [[ "$HOST" = "ghcr.io" || "$HOST" = "gchr.io" ]]; then
    HOST="github.com"
  fi

  REQUIRED_SCOPE="read:packages"

  # Fetch username, token, and scopes in a single local query (works with keyring and GH_TOKEN/GITHUB_TOKEN)
  DATA=$(gh auth status --json hosts --show-token --jq '.hosts["'"$HOST"'"] | (.[] | select(.active == true)) // .[0] | "\(.login)\n\(.token)\n\(.scopes)"' 2>/dev/null || true)

  USERNAME=""
  TOKEN=""
  SCOPES=""

  if [[ -n "$DATA" ]]; then
    USERNAME=$(echo "$DATA" | sed -n '1p')
    TOKEN=$(echo "$DATA" | sed -n '2p')
    SCOPES=$(echo "$DATA" | sed -n '3p')
  fi

  # Normalize scopes by replacing commas with spaces for robust matching
  SCOPES_CLEAN=" ${SCOPES//,/ } "

  # Validate token validity, scope presence, and retrieved credentials
  if [[ -z "$SCOPES" || ! "$SCOPES_CLEAN" == *" $REQUIRED_SCOPE "* || -z "$USERNAME" || -z "$TOKEN" ]]; then
    echo "Error: Token for $HOST is invalid, missing required scope '$REQUIRED_SCOPE', or could not retrieve credentials." >&2
    exit 1
  fi

  # Return the credential helper standard JSON response
  jq --compact-output --null-input --monochrome-output --arg server "$HOST" --arg user "$USERNAME" --arg pass "$TOKEN" '{ServerUrl: $server, Username: $user, Secret: $pass}'
  ;;
*)
  echo "Usage: $0 {get|list|store|erase|version}" >&2
  exit 1
  ;;
esac
