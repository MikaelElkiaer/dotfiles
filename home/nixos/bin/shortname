#!/usr/bin/env bash

set -Eeu -o pipefail

function shortname() {
  local input="$1"
  local output=""
  while [[ -n "$input" ]]; do
    if [[ "$input" =~ ^[a-zA-Z]+ ]]; then
      local chunk="${BASH_REMATCH[0]}"
      local keep=""
      if [[ "$chunk" =~ ^[A-Z] ]]; then
        keep="${chunk//[!A-Z]/}"
      elif [[ "$chunk" =~ ^[a-z] && "$chunk" =~ [A-Z] ]]; then
        local rest="${chunk:1}"
        keep="${chunk:0:1}${rest//[!A-Z]/}"
      else
        keep="${chunk:0:1}"
      fi
      output+="$keep"
      input="${input:${#chunk}}"
    elif [[ "$input" =~ ^[0-9]+ ]]; then
      local chunk="${BASH_REMATCH[0]}"
      output+="$chunk"
      input="${input:${#chunk}}"
    else
      local chunk="${input:0:1}"
      output+="$chunk"
      input="${input:1}"
    fi
  done
  echo -n "$output"
}

# If run directly as a script
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  if [ -n "${1:-}" ] && [ "$1" != "-" ]; then
    shortname "$1"
    echo ""
  else
    input=$(cat)
    shortname "$input"
    echo ""
  fi
fi
